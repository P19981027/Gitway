# ===== Server =====
PORT=3001
NODE_ENV=production
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-96-char-random-hex
JWT_REFRESH_SECRET=replace-with-another-96-char-random-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== SMS provider (pick one — Twilio is recommended if you don't have a Korean phone number) =====
# Twilio — https://www.twilio.com (signup with credit card, buy a US number ~$1.5/month)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+15551234567

# CoolSMS — https://coolsms.co.kr (Korean sender number required, KYC needed)
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_SENDER=

# ===== Email SMTP (Brevo / Sendinblue) =====
# Signup at https://onboarding.brevo.com, verify sender email, get SMTP key from
# https://app.brevo.com/settings/keys/smtp. Add your server's IP to authorized IPs.
# Login (SMTP_USER) is the master SMTP login shown on Brevo's SMTP page (NOT your email).
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ===== Database =====
DB_PATH=./data/giftway.db

# ===== Frontend URL (CORS origin) =====
# Set to the production domain (no trailing slash)
CLIENT_URL=https://your-domain.com

# ===== USDT defaults =====
DEFAULT_USDT_ADDRESS=
DEFAULT_EXCHANGE_RATE=1350
